---
import Layout from '../layouts/Layout.astro';

// Import all lodge images for the hero carousel
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/luxehauslodge/*.{jpeg,jpg,png,gif}');
const imageEntries = Object.entries(allImages);
const images: ImageMetadata[] = [];
for (const [, resolver] of imageEntries) {
  const mod = await resolver();
  images.push(mod.default);
}

// Get all lodge content
const lodgeFiles = import.meta.glob<{ frontmatter: Record<string, any>; default: any }>('../content/lodges/*.md', { eager: true });
const lodges = Object.values(lodgeFiles);
---

<Layout title="Hocking Luxury Lodges">
  <div class="container pt-4">
    <div class="row">
      <div class="col text-center">
        <h1>It All Starts Here</h1>
      </div>
    </div>
  </div>
  <div class="container">
    <!-- Carousel wrapper -->
    <div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel" data-bs-config={'{"interval": 4000, "pause": false}'}>
      <!-- Slides -->
      <div class="carousel-inner mb-5">
        <div class="carousel-inner mb-1">
          {images.map((img, i) => (
            <div class={`carousel-item ${i === 0 ? 'active' : ''}`}>
              <img
                src={img.src}
                loading={i === 0 ? 'eager' : 'lazy'}
                class="d-block w-100"
                alt="Hocking Luxury Lodges"
                style="height:35vw; object-fit: cover;"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Controls -->
      <button class="carousel-control-prev position-absolute top-50 start-0 translate-middle-y" style="height: 50px; width: 50px;"
        type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button class="carousel-control-next top-50 position-absolute end-0 translate-middle-y"
        style="height: 50px; width: 50px;" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
    </div>
  </div>

  <!-- Lodge Cards -->
  <div class="container py-5">
    <div class="row">
      {lodges.map((lodge) => (
        <div class="col-md-6 mb-4">
          <div class="card">
            {lodge.frontmatter.cardImage && (
              <img src={`/assets/images/${lodge.frontmatter.cardImage}`} class="card-img-top" alt={lodge.frontmatter.title} />
            )}
            <div class="card-body">
              <h5 class="card-title">{lodge.frontmatter.title}</h5>
              <p class="card-text">{lodge.frontmatter.excerpt}</p>
              <a href={lodge.frontmatter.slug} class="btn btn-primary">View Lodge</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

---
// LanguageSwitcher.astro
// Renders a flag dropdown that lets users toggle between English and Spanish.
// The selected language is stored in sessionStorage under the key "siteLanguage".
---

<div class="lang-switcher dropdown">
  <button
    class="lang-switcher-btn btn dropdown-toggle"
    type="button"
    id="langDropdown"
    data-bs-toggle="dropdown"
    aria-expanded="false"
    aria-label="Select language"
  >
    <span id="lang-flag" class="flag-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 7410 3900"><path fill="#b22234" d="M0 0h7410v3900H0"/><path d="M0 450h7410m0 600H0m0 600h7410m0 600H0m0 600h7410m0 600H0" stroke="#fff" stroke-width="300"/><path fill="#3c3b6e" d="M0 0h2964v2100H0"/><g fill="#fff"><g id="s18"><g id="s9"><g id="s5"><g id="s4"><path id="s" d="M247 90l70.534 217.082-184.66-134.164h228.253L176.466 307.082z"/><use href="#s" y="420"/><use href="#s" y="840"/><use href="#s" y="1260"/></g><use href="#s" y="1680"/></g><use href="#s4" x="247" y="210"/></g><use href="#s9" x="494"/></g><use href="#s18" x="988"/><use href="#s9" x="1976"/><use href="#s5" x="2470"/></g></svg></span>
    <span id="lang-label" class="lang-label">EN</span>
  </button>
  <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="langDropdown">
    <li>
      <button class="dropdown-item lang-option" data-lang-switch="en">
        <span class="flag-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 7410 3900"><path fill="#b22234" d="M0 0h7410v3900H0"/><path d="M0 450h7410m0 600H0m0 600h7410m0 600H0m0 600h7410m0 600H0" stroke="#fff" stroke-width="300"/><path fill="#3c3b6e" d="M0 0h2964v2100H0"/><g fill="#fff"><g id="s18b"><g id="s9b"><g id="s5b"><g id="s4b"><path id="sb" d="M247 90l70.534 217.082-184.66-134.164h228.253L176.466 307.082z"/><use href="#sb" y="420"/><use href="#sb" y="840"/><use href="#sb" y="1260"/></g><use href="#sb" y="1680"/></g><use href="#s4b" x="247" y="210"/></g><use href="#s9b" x="494"/></g><use href="#s18b" x="988"/><use href="#s9b" x="1976"/><use href="#s5b" x="2470"/></g></svg></span> English
      </button>
    </li>
    <li>
      <button class="dropdown-item lang-option" data-lang-switch="es">
        <span class="flag-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 750 500"><rect width="750" height="500" fill="#c60b1e"/><rect width="750" height="250" y="125" fill="#ffc400"/></svg></span> Español
      </button>
    </li>
  </ul>
</div>

<style>
  .lang-switcher-btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: #fff;
    padding: 4px 10px;
    font-size: 0.875rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .lang-switcher-btn:hover,
  .lang-switcher-btn:focus {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.8);
  }
  .lang-switcher-btn::after {
    margin-left: 4px;
  }
  .lang-label {
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .dropdown-menu {
    min-width: 130px;
  }
  .dropdown-item {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .flag-icon {
    display: inline-flex;
    width: 1.2em;
    height: 0.85em;
    vertical-align: middle;
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .flag-icon svg {
    width: 100%;
    height: 100%;
  }
</style>

---
import Layout from './Layout.astro';
import { getImage } from 'astro:assets';

export interface Props {
  title: string;
  unitId?: string;
  imageFolder?: string;
  airbnbUrl?: string;
  vrboUrl?: string;
  petFriendly?: boolean;
  youtubeId?: string;
  guests?: number;
  bedrooms?: number;
  beds?: number;
  bathrooms?: number | string;
  sleeping?: string[];
  amenities?: { icon: string; title: string; items: string[] }[];
  goodToKnow?: string[];
  reviews?: { quote: string; author: string; location?: string }[];
}

const {
  title, unitId, imageFolder = 'luxehauslodge',
  airbnbUrl, vrboUrl, petFriendly, youtubeId,
  guests, bedrooms, beds, bathrooms,
  sleeping = [], amenities = [], goodToKnow = [],
  reviews = [],
} = Astro.props;

// Import all lodge images, filter to current lodge
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,gif}');
const filteredEntries = Object.entries(allImages).filter(([path]) =>
  path.includes(`/images/${imageFolder}/`)
);

// Group images by subfolder (skip top-level files like cover.jpg)
interface OptimizedImage {
  thumb: string;
  full: string;
  width: number;
  height: number;
}

const sections: Record<string, OptimizedImage[]> = {};
for (const [path, resolver] of filteredEntries) {
  const mod = await resolver();
  const afterLodge = path.split(`/images/${imageFolder}/`)[1];
  const parts = afterLodge.split('/');
  if (parts.length <= 1) continue; // skip top-level files
  const section = parts[0];
  if (!sections[section]) sections[section] = [];

  // Generate optimized thumbnail (400px wide, WebP) and full-size (1400px, WebP)
  const [thumb, full] = await Promise.all([
    getImage({ src: mod.default, width: 400, format: 'webp', quality: 75 }),
    getImage({ src: mod.default, width: 1400, format: 'webp', quality: 80 }),
  ]);

  sections[section].push({
    thumb: thumb.src,
    full: full.src,
    width: thumb.attributes.width as number,
    height: thumb.attributes.height as number,
  });
}

function formatSectionTitle(key: string): string {
  if (key === '_overview') return 'Overview';
  return key.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

const sectionKeys = Object.keys(sections).sort((a, b) => {
  if (a === '_overview') return -1;
  if (b === '_overview') return 1;
  if (a === 'other') return 1;
  if (b === 'other') return -1;
  return a.localeCompare(b);
});

// Get first image for hero (optimized for large display)
const heroRaw = sectionKeys.length > 0 ? sections[sectionKeys[0]][0] : null;
const heroSrc = heroRaw ? heroRaw.full : null;

// Use cover.jpg as the hero image
const coverEntry = filteredEntries.find(([path]) => {
  const afterLodge = path.split(`/images/${imageFolder}/`)[1];
  return afterLodge === 'cover.jpg' || afterLodge === 'cover.jpeg' || afterLodge === 'cover.png';
});
let heroOptimizedSrc: string | null = null;
if (coverEntry) {
  const coverMod = await coverEntry[1]();
  const heroOpt = await getImage({ src: coverMod.default, width: 1600, format: 'webp', quality: 80 });
  heroOptimizedSrc = heroOpt.src;
} else if (sectionKeys.length > 0) {
  // Fallback to first gallery image if no cover exists
  heroOptimizedSrc = sections[sectionKeys[0]][0]?.full ?? null;
}
---

<Layout title={`${title} - Hocking Luxury Lodges`} description={`${title} — sleeps up to ${guests || 10} guests with ${bedrooms || 4} bedrooms, ${bathrooms || 3} baths. Book your Hocking Hills luxury getaway.`} ogType="website">
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VacationRental",
    "name": title,
    "description": `${title} — luxury vacation rental in Hocking Hills, Ohio.`,
    "url": `https://hockingluxurylodges.com${Astro.url.pathname}`,
    "image": heroOptimizedSrc ? `https://hockingluxurylodges.com${heroOptimizedSrc}` : undefined,
    "occupancy": {
      "@type": "QuantitativeValue",
      "maxValue": guests || 10
    },
    "numberOfBedrooms": bedrooms,
    "numberOfBathroomsTotal": typeof bathrooms === 'number' ? bathrooms : undefined,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Logan",
      "addressRegion": "OH",
      "addressCountry": "US"
    }
  })} />
  <!-- Preload hero image for fastest LCP -->
  {heroOptimizedSrc && (
    <link rel="preload" as="image" href={heroOptimizedSrc} type="image/webp" />
  )}
  <!-- Hero section -->
  {heroOptimizedSrc && (
    <div class="lodge-hero">
      <img src={heroOptimizedSrc} alt={title} class="lodge-hero-bg" width="1600" height="1067" fetchpriority="high" decoding="async" />
      <a href="/#lodges" class="lodge-back-link"><i class="fa-solid fa-arrow-left"></i> All Lodges</a>
      <div class="lodge-hero-overlay">
        <div class="container">
          <h1 class="lodge-hero-title">{title}</h1>
          {(guests || bedrooms || bathrooms) && (
            <div class="lodge-hero-stats">
              {guests && <span><i class="fa-solid fa-users"></i> Up to {guests} guests</span>}
              {bedrooms && <span><i class="fa-solid fa-bed"></i> {bedrooms} bedrooms</span>}
              {beds && <span><i class="fa-solid fa-bed"></i> {beds} beds</span>}
              {bathrooms && <span><i class="fa-solid fa-bath"></i> {bathrooms} baths</span>}
              {petFriendly && <span class="pet-friendly-badge"><i class="fa-solid fa-paw"></i> Pet Friendly</span>}
            </div>
          )}
          {(airbnbUrl || vrboUrl) && (
            <div class="d-flex gap-3 flex-wrap mt-3">
              {airbnbUrl && (
                <a href={airbnbUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline-booking btn-airbnb">
                  <i class="fa-brands fa-airbnb me-1"></i> Airbnb
                </a>
              )}
              {vrboUrl && (
                <a href={vrboUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline-booking btn-vrbo">
                  <i class="fa-solid fa-house-chimney me-1"></i> Vrbo
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  <div class="container lodge-content">
    <!-- Two-column grid: description + details side by side on desktop -->
    <div class="row g-4 mt-2">
      <!-- Left column: description + video -->
      <div class="col-lg-7">
        <div class="lodge-card">
          <h5 class="lodge-card-header"><i class="fa-solid fa-house"></i> About this space</h5>
          <div class="lodge-card-body">
            <slot />
          </div>
        </div>

        {youtubeId && (
          <div class="lodge-card mt-4">
            <h5 class="lodge-card-header"><i class="fa-solid fa-video"></i> Video Tour</h5>
            <div class="lodge-card-body p-0">
              <div class="ratio ratio-16x9">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
                  title={`${title} Video Tour`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  style="border-radius: 0 0 var(--brand-radius) var(--brand-radius);"
                ></iframe>
              </div>
            </div>
          </div>
        )}

        {goodToKnow.length > 0 && (
          <div class="lodge-card mt-4">
            <h5 class="lodge-card-header"><i class="fa-solid fa-circle-info"></i> Good to Know</h5>
            <div class="lodge-card-body">
              <ul class="lodge-list">
                {goodToKnow.map((note) => (
                  <li set:html={note.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')} />
                ))}
              </ul>
            </div>
          </div>
        )}

        {reviews.length > 0 && (
          <div class="lodge-card mt-4">
            <h5 class="lodge-card-header"><i class="fa-solid fa-star"></i> What Guests Are Saying</h5>
            <div class="lodge-card-body">
              <div class="reviews-grid">
                {reviews.map((review) => (
                  <blockquote class="review-card">
                    <p class="review-quote">&ldquo;{review.quote}&rdquo;</p>
                    <footer class="review-author">
                      <strong>{review.author}</strong>
                      {review.location && <span class="review-location">{review.location}</span>}
                    </footer>
                  </blockquote>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- Right column: sleeping + compact amenity cards -->
      <div class="col-lg-5">
        {sleeping.length > 0 && (
          <div class="lodge-card">
            <h5 class="lodge-card-header"><i class="fa-solid fa-bed"></i> Sleeping & Bathrooms</h5>
            <div class="lodge-card-body">
              <ul class="lodge-list">
                {sleeping.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        )}

        {amenities.length > 0 && (
          <div class="lodge-card mt-4">
            <h5 class="lodge-card-header"><i class="fa-solid fa-star"></i> Amenities</h5>
            <div class="lodge-card-body lodge-amenities-grid">
              {amenities.map((group) => (
                <div class="amenity-group">
                  <h6 class="amenity-group-title">
                    <i class={group.icon}></i> {group.title}
                  </h6>
                  <ul class="amenity-items">
                    {group.items.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Photo gallery -->
  {sectionKeys.length > 0 && (
    <div class="container mt-5">
      <h3 class="mb-4">{title} Photos</h3>
      <div class="gallery-tabs">
        <button class="gallery-tab active" data-tab="by-room">By Room</button>
        <button class="gallery-tab" data-tab="all-photos">All Photos</button>
      </div>

      <!-- By Room view -->
      <div class="gallery-tab-content active" id="tab-by-room">
        <div class="room-grid">
          {(() => {
            let runningIndex = 0;
            return sectionKeys.map((key) => {
              const images = sections[key];
              const firstImg = images[0];
              const startIndex = runningIndex;
              runningIndex += images.length;
              return (
                <a href={firstImg.full} class="room-card" data-lightbox data-section={formatSectionTitle(key)} data-room-start={startIndex}>
                  <div class="room-card-img">
                    <img src={firstImg.thumb} width={firstImg.width} height={firstImg.height} alt={formatSectionTitle(key)} loading="lazy" decoding="async" />
                    <span class="room-card-count"><i class="fa-solid fa-images"></i> {images.length}</span>
                  </div>
                  <div class="room-card-name">{formatSectionTitle(key)}</div>
                </a>
              );
            });
          })()}
        </div>
      </div>

      <!-- All Photos view -->
      <div class="gallery-tab-content" id="tab-all-photos">
        {sectionKeys.map((key) => (
          <div class="gallery-section mb-5">
            <h5 class="gallery-section-title">{formatSectionTitle(key)}</h5>
            <div class="photo-grid">
              {sections[key].map((img, i) => (
                <a href={img.full} class="photo-grid-item" data-lightbox data-section={formatSectionTitle(key)}>
                  <img src={img.thumb} width={img.width} height={img.height} alt={`${title} - ${formatSectionTitle(key)} ${i + 1}`} loading="lazy" decoding="async" />
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Lightbox overlay -->
  <div id="lightbox" class="lightbox-overlay" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox-prev" aria-label="Previous">&lsaquo;</button>
    <button class="lightbox-next" aria-label="Next">&rsaquo;</button>
    <img id="lightbox-img" src="" alt="" />
    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>

  <script is:inline>
  (function() {
    var overlay = document.getElementById('lightbox');
    var lbImg = document.getElementById('lightbox-img');
    var lbCaption = document.getElementById('lightbox-caption');
    var currentIndex = -1;

    function getActiveLinks() {
      var active = document.querySelector('.gallery-tab-content.active');
      return active ? Array.from(active.querySelectorAll('[data-lightbox]')) : [];
    }

    var links = getActiveLinks();

    function updateCaption(index) {
      var section = links[index].getAttribute('data-section') || '';
      lbCaption.textContent = section;
    }

    function openLightbox(index) {
      currentIndex = index;
      lbImg.src = links[index].href;
      var img = links[index].querySelector('img');
      lbImg.alt = img ? img.alt : '';
      updateCaption(index);
      overlay.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
    }

    function closeLightbox() {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      lbImg.src = '';
      lbCaption.textContent = '';
    }

    function navigate(dir) {
      currentIndex = (currentIndex + dir + links.length) % links.length;
      lbImg.src = links[currentIndex].href;
      var img = links[currentIndex].querySelector('img');
      lbImg.alt = img ? img.alt : '';
      updateCaption(currentIndex);
    }

    function bindLinks() {
      links = getActiveLinks();
      links.forEach(function(link, i) {
        link.onclick = function(e) {
          e.preventDefault();
          // For room cards, get the all-photos links and open at the room start index
          var roomStart = link.getAttribute('data-room-start');
          if (roomStart !== null) {
            var allTab = document.getElementById('tab-all-photos');
            var allLinks = Array.from(allTab.querySelectorAll('[data-lightbox]'));
            links = allLinks;
            openLightbox(parseInt(roomStart, 10));
          } else {
            openLightbox(i);
          }
        };
      });
    }

    bindLinks();

    // Tab switching
    var tabs = document.querySelectorAll('.gallery-tab');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        var target = tab.getAttribute('data-tab');
        document.querySelectorAll('.gallery-tab-content').forEach(function(c) {
          c.classList.toggle('active', c.id === 'tab-' + target);
        });
        bindLinks();
      });
    });

    overlay.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
    overlay.querySelector('.lightbox-prev').addEventListener('click', function() { navigate(-1); });
    overlay.querySelector('.lightbox-next').addEventListener('click', function() { navigate(1); });
    overlay.addEventListener('click', function(e) { if (e.target === overlay) closeLightbox(); });
    document.addEventListener('keydown', function(e) {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
  })();
  </script>

  {(airbnbUrl || vrboUrl) && (
    <div class="floating-book-bar" id="floatingBookBar">
      <span class="floating-book-label">Book Now</span>
      <div class="floating-book-buttons">
        {airbnbUrl && (
          <a href={airbnbUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline-booking btn-airbnb">
            <i class="fa-brands fa-airbnb me-1"></i> Airbnb
          </a>
        )}
        {vrboUrl && (
          <a href={vrboUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline-booking btn-vrbo">
            <i class="fa-solid fa-house-chimney me-1"></i> Vrbo
          </a>
        )}
      </div>
    </div>
  )}

  <script>
    (function() {
      const hero = document.querySelector('.lodge-hero');
      const bar = document.getElementById('floatingBookBar');
      if (!hero || !bar) return;
      function toggle() {
        const heroBottom = hero.getBoundingClientRect().bottom;
        bar.classList.toggle('visible', heroBottom < 0);
      }
      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
    })();
  </script>
</Layout>
